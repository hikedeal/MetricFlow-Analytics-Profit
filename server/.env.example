# Environment
NODE_ENV=development
PORT=5000

# Shopify Configuration
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_SCOPES=read_orders,read_customers,read_products,read_inventory,read_discounts,read_fulfillments,write_orders,write_customers
SHOPIFY_APP_URL=https://your-app-url.ngrok.io
SHOPIFY_API_VERSION=2024-01

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/adynic_performance

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Session & Security
SESSION_SECRET=your_super_secret_session_key_change_this_in_production
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (for scheduled reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@adynic.com

# App Configuration
APP_NAME=Adynic Performance
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Background Jobs
ENABLE_BACKGROUND_JOBS=true
SYNC_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_PROFIT_TRACKING=true
ENABLE_MARKETING_INTELLIGENCE=false
ENABLE_SCHEDULED_REPORTS=true
